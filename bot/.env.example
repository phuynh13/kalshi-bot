# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kalshi credentials ───────────────────────────────────────────────────────
DEMO_MODE=true
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# ── Strategy parameters ──────────────────────────────────────────────────────
DAILY_SPEND_LIMIT=10.00
MIN_PROBABILITY=0.58
MAX_PROBABILITY=0.85
CONTRACTS_PER_ORDER=1
MIN_VOLUME_24H=50
MAX_SPREAD=0.10
HOURS_TO_CLOSE=24

# ── Optional category exclusions (comma-separated) ───────────────────────────
# Known Kalshi categories: Economics, Politics, Sports, Climate and Weather,
# Finance, Technology, Entertainment, Pop Culture, Crypto, Health, Geopolitics,
# Awards, Science
EXCLUDED_CATEGORIES=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
